# ARSA Technology Edge-TTS Configuration
TTS_MAX_TEXT_LENGTH=5000
TTS_CLEANUP_INTERVAL=3600
PYTHONUNBUFFERED=1
OUTPUT_DIR=./app/output
HOST_OUTPUT_DIR=/www/wwwroot/nama_project/audio

# === Authentication (production) ===
# Leave empty to DISABLE auth (dev mode). For prod, set a strong random key.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=
# Optional: multiple valid keys (comma-separated). If set, takes precedence over API_KEY.
# API_KEYS=key-for-app-a,key-for-app-b,key-for-app-c
# Optional: customize the header name clients must send (default: X-API-Key)
API_KEY_HEADER=X-API-Key

# === Rate Limiting ===
# Syntax: "<count>/<period>" where period = second | minute | hour | day
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_TTS=30/minute
RATE_LIMIT_TTS_BATCH=5/minute
RATE_LIMIT_AUDIO=120/minute
RATE_LIMIT_STATS=30/minute
# Storage backend. Use "memory://" for single-process; use redis for multi-replica deploys.
# Example: redis://redis:6379
RATE_LIMIT_STORAGE_URI=memory://
